   "source": [
    "This notebook allows users to compare any 2 teams. First, several graphs compare both teams' stats, so the user can see how they match up. Then, the program simulates a playoff series between them. The function `n_simulations` runs many simulations (default = 25) of this playoff series and prints both teams' probabilities of winning it.\n",
    "\n",
    "The user should modify `team` and `opp` in the second code cell, as well as `n` for the number of simulations they want to run."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "a443ef4d",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import sys\n",
    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "sys.path.append(\"../src\")\n",
    "\n",
    "from fetch_gamelog import gamelog\n",
    "from predict_result import simulate_series, n_simulations, train_model\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "74bc1065",
   "metadata": {},
   "outputs": [],
   "source": [
    "team = \"COL\" #user input\n",
    "opp = \"CAR\" #user input\n",
    "\n",
    "team_gamelog = gamelog(team)\n",
    "opp_gamelog = gamelog(opp)\n",
    "\n",
    "def length(df):\n",
    "    return df[(\"Score\", \"Rslt\")].shape[0]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "28961ddd",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#Points through the season\n",
    "\n",
    "plt.figure(figsize = (10, 5))\n",
    "plt.step(team_gamelog[(\"Unnamed: 2_level_0\", \"Date\")], team_gamelog[('Unnamed: 5_level_0', 'Points')], where='post', label=team)\n",
    "plt.step(opp_gamelog[(\"Unnamed: 2_level_0\", \"Date\")], opp_gamelog[('Unnamed: 5_level_0', 'Points')], where='post', label=opp)\n",
    "\n",
    "plt.title('Points Through Season')\n",
    "plt.grid(True, axis='both', linestyle='--', alpha=0.7)\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "1aff1552",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#Comparison of Shots on Goal\n",
    "\n",
    "data1 = team_gamelog[('Team', 'SOG')]\n",
    "data2 = opp_gamelog[('Team', 'SOG')]\n",
    "plt.hist(data1, label = team, alpha = 0.5); \n",
    "plt.hist(data2, label = opp, alpha = 0.5);\n",
    "plt.xlabel(\"Shots on Goal\");\n",
    "plt.ylabel(\"# of Games\");\n",
    "plt.legend();\n",
    "plt.show();"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "c0ad0358",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#Comparison of Power Play Goals vs. Opportunities\n",
    "def pp_success(ppg, ppo):\n",
    "    return ppg / ppo\n",
    "\n",
    "data1 = pp_success(team_gamelog[('Team', 'PPG')], team_gamelog[('Team', 'PPO')])\n",
    "data2 = pp_success(opp_gamelog[('Team', 'PPG')], opp_gamelog[('Team', 'PPO')])      \n",
    "plt.hist(data1, label = team, alpha = 0.5); \n",
    "plt.hist(data2, label = opp, alpha = 0.5);\n",
    "plt.xlabel(\"Power Play Goals vs. Opportunities\");\n",
    "plt.ylabel(\"# of Games\");\n",
    "plt.legend();\n",
    "plt.show();"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "c664dfd4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "#Comparison of Save %\n",
    "def save_pct(ga, sog):\n",
    "    return 1 - (ga / sog)\n",
    "\n",
    "data1 = save_pct(team_gamelog[('Score', 'GA')], team_gamelog[('Opponent', 'SOG')])\n",
    "data2 = save_pct(opp_gamelog[('Score', 'GA')], opp_gamelog[('Opponent', 'SOG')])\n",
    "plt.hist(data1, label = team, alpha = 0.5); \n",
    "plt.hist(data2, label = opp, alpha = 0.5);\n",
    "plt.xlabel(\"Save %\");\n",
    "plt.ylabel(\"# of Games\");\n",
    "plt.legend();\n",
    "plt.show();"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "b5d64f9f",
   "metadata": {},
   "outputs": [],
   "source": [
    "model1, scaler1 = train_model(team_gamelog)\n",
    "model2, scaler2 = train_model(opp_gamelog)\n",
    "models = [model1, model2]\n",
    "scalers = [scaler1, scaler2]"
   ]
  },
